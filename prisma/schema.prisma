generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  department     String?
  chatgptUserId  String?  @unique @map("chatgpt_user_id")
  claudeUserId   String?  @unique @map("claude_user_id")
  hubspotOwnerId String?  @unique @map("hubspot_owner_id")
  m365UserId     String?  @unique @map("m365_user_id")
  costTier       String?  @map("cost_tier")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  usageRecords UsageRecord[]
  costRecords  CostRecord[]

  @@map("users")
}

model UsageRecord {
  id           String   @id @default(cuid())
  userId       String?  @map("user_id")
  platform     String
  model        String
  date         DateTime @db.Date
  inputTokens  BigInt   @default(0) @map("input_tokens")
  outputTokens BigInt   @default(0) @map("output_tokens")
  totalTokens  BigInt   @default(0) @map("total_tokens")
  requests     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([platform])
  @@index([date])
  @@index([userId])
  @@unique([platform, date, model, userId])
  @@map("usage_records")
}

model CostRecord {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  platform  String
  date      DateTime @db.Date
  amount    Decimal  @db.Decimal(10, 6)
  category  String?
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([platform])
  @@index([date])
  @@index([userId])
  @@unique([platform, date, category])
  @@map("cost_records")
}

model SyncLog {
  id          String   @id @default(cuid())
  platform    String
  syncedAt    DateTime @default(now()) @map("synced_at")
  status      String   @default("success")
  message     String?
  recordCount Int?     @map("record_count")

  @@index([platform])
  @@map("sync_logs")
}

model HubSpotOwner {
  id        String  @id
  email     String
  firstName String? @map("first_name")
  lastName  String? @map("last_name")
  teamName  String? @map("team_name")

  @@map("hubspot_owners")
}

model HubSpotPipelineStage {
  id            String @id @default(cuid())
  pipelineId    String @map("pipeline_id")
  pipelineLabel String @map("pipeline_label")
  stageId       String @map("stage_id")
  stageLabel    String @map("stage_label")
  displayOrder  Int    @map("display_order")
  probability   Float  @default(0)

  @@unique([pipelineId, stageId])
  @@map("hubspot_pipeline_stages")
}

model HubSpotDeal {
  id            String    @id
  name          String
  stage         String
  stageLabel    String?   @map("stage_label")
  pipeline      String
  pipelineLabel String?   @map("pipeline_label")
  amount        Decimal?  @db.Decimal(12, 2)
  closeDate     DateTime? @map("close_date")
  ownerId       String?   @map("owner_id")
  ownerName     String?   @map("owner_name")
  createdAt     DateTime  @map("hs_created_at")
  lastModified  DateTime  @map("last_modified")
  daysInStage   Int?      @map("days_in_stage")
  syncedAt      DateTime  @default(now()) @map("synced_at")

  @@index([pipeline])
  @@index([ownerId])
  @@index([stage])
  @@map("hubspot_deals")
}

model HubSpotCompany {
  id                 String    @id
  name               String
  domain             String?
  ownerId            String?   @map("owner_id")
  ownerName          String?   @map("owner_name")
  lastContacted      DateTime? @map("last_contacted")
  lastActivity       DateTime? @map("last_activity")
  associatedContacts Int       @default(0) @map("associated_contacts")
  associatedDeals    Int       @default(0) @map("associated_deals")
  createdAt          DateTime  @map("hs_created_at")
  syncedAt           DateTime  @default(now()) @map("synced_at")

  @@map("hubspot_companies")
}

model HubSpotContact {
  id             String   @id
  email          String?
  firstName      String?  @map("first_name")
  lastName       String?  @map("last_name")
  company        String?
  jobTitle       String?  @map("job_title")
  phone          String?
  lifecycleStage String?  @map("lifecycle_stage")
  ownerId        String?  @map("owner_id")
  createdAt      DateTime @map("hs_created_at")
  lastModified   DateTime @map("last_modified")
  syncedAt       DateTime @default(now()) @map("synced_at")

  @@index([ownerId])
  @@index([lifecycleStage])
  @@map("hubspot_contacts")
}

model HubSpotEngagement {
  id         String   @id
  type       String
  ownerId    String?  @map("owner_id")
  companyId  String?  @map("company_id")
  contactId  String?  @map("contact_id")
  dealId     String?  @map("deal_id")
  occurredAt DateTime @map("occurred_at")
  syncedAt   DateTime @default(now()) @map("synced_at")

  @@index([type])
  @@index([ownerId])
  @@index([occurredAt])
  @@map("hubspot_engagements")
}

model ProductivityConfig {
  id          String  @id @default(cuid())
  key         String  @unique
  value       String
  label       String
  description String?

  @@map("productivity_config")
}
